#
# iCloud
#

IMAPAccount iCloud
Host imap.mail.me.com
PORT 993
User julio.villasante@icloud.com
PassCmd "pass show Apps/mu4e-icloud | head -n1"
AuthMechs LOGIN
TLSType IMAPS
CertificateFile /etc/ssl/certs/ca-certificates.crt

MaildirStore iCloud-local
Path ~/.mail/julio.villasante@icloud.com/
Inbox ~/.mail/julio.villasante@icloud.com/Inbox
SubFolders Verbatim

IMAPStore iCloud-remote
Account iCloud

Channel iCloud-all
Far :iCloud-remote:
Near :iCloud-local:
Patterns "INBOX" "Archive" "Drafts"
CopyArrivalDate yes
Create Both
Expunge Both
SyncState *

Channel iCloud-sent
Far :iCloud-remote:"Sent Messages"
Near :iCloud-local:"Sent"
CopyArrivalDate yes
Create Both
Expunge Both
SyncState *

Channel iCloud-junk
Far :iCloud-remote:"Junk"
Near :iCloud-local:"Spam"
CopyArrivalDate yes
Create Both
Expunge Both
SyncState *

Channel iCloud-trash
Far :iCloud-remote:"Deleted Messages"
Near :iCloud-local:"Trash"
CopyArrivalDate yes
Create Both
Expunge Both
SyncState *

Group iCloud
Channel iCloud-sent
Channel iCloud-junk
Channel iCloud-trash
Channel iCloud-all

#
# Omicron (Outlook)
#

IMAPAccount Omicron
Host outlook.office365.com
User julio.villasante@omicronmedia.com
AuthMechs XOAUTH2
PassCmd "/usr/local/bin/mutt_oauth2.py ~/.mbsync_work_token"
TLSType IMAPS
CertificateFile /etc/ssl/certs/ca-certificates.crt

MaildirStore Omicron-local
Path ~/.mail/julio.villasante@omicronmedia.com/
Inbox ~/.mail/julio.villasante@omicronmedia.com/Inbox
SubFolders Verbatim

IMAPStore Omicron-remote
Account Omicron

Channel Omicron-all
Far :Omicron-remote:
Near :Omicron-local:
Patterns "INBOX" "Archive" "Drafts"
CopyArrivalDate yes
Create Both
Expunge Both
SyncState *

Channel Omicron-sent
Far :Omicron-remote:"Sent Items"
Near :Omicron-local:"Sent"
CopyArrivalDate yes
Create Both
Expunge Both
SyncState *

Channel Omicron-junk
Far :Omicron-remote:"Junk Email"
Near :Omicron-local:"Spam"
CopyArrivalDate yes
Create Both
Expunge Both
SyncState *

Channel Omicron-trash
Far :Omicron-remote:"Deleted Items"
Near :Omicron-local:"Trash"
CopyArrivalDate yes
Create Both
Expunge Both
SyncState *

Channel Omicron-nightly
Far :Omicron-remote:"Nightly Builds"
Near :Omicron-local:"Nightly"
CopyArrivalDate yes
Create Both
Expunge Both
SyncState *

Group Omicron
Channel Omicron-all
Channel Omicron-sent
Channel Omicron-junk
Channel Omicron-trash
Channel Omicron-nightly
