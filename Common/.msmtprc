# Set default values for all following accounts.
defaults
auth           on
tls            on
tls_trust_file /etc/ssl/certs/ca-certificates.crt
logfile        ~/.mail/msmtp.log

# iCloud (Using an App Password)
account        icloud
host           smtp.mail.me.com
port           587
from           julio.villasante@icloud.com
user           julio.villasante@icloud.com
passwordeval   pass show Apps/mu4e-icloud | head -n1

# Omicron (Office 365 with OAuth2)
account        omicron
host           smtp.office365.com
port           587
from           julio.villasante@omicronmedia.com
user           julio.villasante@omicronmedia.com
auth           xoauth2
passwordeval   /usr/local/bin/mutt_oauth2.py ~/.mbsync_work_token

# Set a default account
account default : icloud
