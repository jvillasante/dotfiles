# -*- mode: sh; sh-shell: bash -*-

#
# fzf
#
if type fzf > /dev/null 2> /dev/null; then
    # Source the first key-bindings file we find -- elif (not && chain) so
    # we don't double-source on distros that ship both locations.
    if [ -f /usr/share/fzf/shell/key-bindings.bash ]; then
        # shellcheck source=/dev/null
        source /usr/share/fzf/shell/key-bindings.bash
    elif [ -f /usr/share/bash-completion/completions/fzf-key-bindings ]; then
        # shellcheck source=/dev/null
        source /usr/share/bash-completion/completions/fzf-key-bindings
    elif [ -f /usr/share/doc/fzf/examples/key-bindings.bash ]; then
        # shellcheck source=/dev/null
        source /usr/share/doc/fzf/examples/key-bindings.bash
    elif [ -f "$HOME"/.fzf.bash ]; then
        # shellcheck source=/dev/null
        source "$HOME"/.fzf.bash
    fi

    # Use ~~ as the trigger sequence instead of the default **
    # export FZF_COMPLETION_TRIGGER='~~'

    # Options to fzf command
    # export FZF_TMUX_OPTS="-u40%"
    export FZF_DEFAULT_OPTS='--height 80% --ansi --layout=reverse --no-border --info=inline --color=light,gutter:-1,bg+:#e0e0e0'
    export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
    export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"

    # Use fd (https://github.com/sharkdp/fd) instead of the default find
    # command for listing path candidates.
    # - The first argument to the function ($1) is the base path to start traversal
    # - See the source code (completion.{bash,zsh}) for the details.
    _fzf_compgen_path() {
        fd --hidden --follow --exclude ".git" . "$1"
    }

    # Use fd to generate the list for directory completion
    _fzf_compgen_dir() {
        fd --type d --hidden --follow --exclude ".git" . "$1"
    }

    #
    # General
    #

    # fe [FUZZY PATTERN] - Open the selected file with the default editor
    #   - Bypass fuzzy finder if there's only one match (--select-1)
    #   - Exit if there's no match (--exit-0)
    fe() {
        local file
        file=$(fzf --query="$1" --select-1 --exit-0)
        [ -n "$file" ] && ${EDITOR:-vim} "$file"
    }

    # frm - remove selected file
    frm() {
        local file
        file=$(fzf --query="$1" --select-1 --exit-0)
        [ -n "$file" ] && rm "$file"
    }

    # fcd - cd to selected directory (excludes hidden dirs). Renamed from
    # `fd` to avoid shadowing the fd-find binary used in FZF_DEFAULT_COMMAND.
    fcd() {
        local dir
        dir=$(find "${1:-.}" -path '*/\.*' -prune \
                   -o -type d -print 2> /dev/null | fzf +m) && cd "$dir" || return
    }

    # fda - including hidden directories
    fda() {
        local dir
        dir=$(find "${1:-.}" -type d 2> /dev/null | fzf +m) && cd "$dir" || return
    }

    # cdf - cd into the directory of the selected file
    cdf() {
        local file
        local dir
        file=$(fzf +m -q "$1") && dir=$(dirname "$file") && cd "$dir" || return
    }

    # switch to a project
    fproj() {
        local selected tmux_running selected_name d first
        local -a roots=(
            "$HOME/Workspace/Projects/"
            "$HOME/Workspace/Scratch/"
            "$HOME/Workspace/Work/Nielsen/Projects/"
            "$HOME/Workspace/Work/Omicron/Projects/"
        )
        # Directories pruned before recursion -- avoids surfacing vendored
        # dependencies that carry their own .git (e.g. CMake _deps under
        # build/, npm modules under node_modules/, Cargo deps under target/).
        # Edit this list to add or remove patterns.
        local -a skip_dirs=(build node_modules target vendor)

        # Build the find expression: \( -path '*/X' -o -path '*/Y' ... \) -prune -o ...
        local -a find_args=("${roots[@]}")
        if (( ${#skip_dirs[@]} > 0 )); then
            find_args+=(\()
            first=1
            for d in "${skip_dirs[@]}"; do
                (( first )) || find_args+=(-o)
                first=0
                find_args+=(-path "*/$d")
            done
            find_args+=(\) -prune -o)
        fi
        find_args+=(-name .git -printf '%h\n' -prune)

        selected=$(find "${find_args[@]}" \
                   | grep -v "$HOME/Workspace/Work/Omicron/Projects/nntp$" \
                   | fzf)
        [[ -z $selected ]] && return

        # tmux session names cannot contain `.` or `:` -- swap both for `_`.
        selected_name=$(basename "$selected" | tr '.:' '__')
        [[ -z $selected_name ]] && return

        if [[ dmxs = "$selected_name" ]]; then
            "$HOME/Workspace/Projects/dotfiles/Common/shell/tmux/dmxs.session" "$selected" "$selected_name"
            return
        fi

        if [[ sm2-dhcpee = "$selected_name" ]]; then
            "$HOME/Workspace/Projects/dotfiles/Common/shell/tmux/dhcpee.session" "$selected" "$selected_name"
            return
        fi

        if [[ "$selected" == "$HOME/Workspace/Work/Omicron/Projects/nntp/"* ]]; then
            "$HOME/Workspace/Projects/dotfiles/Common/shell/tmux/nntp.session" "$selected" "$selected_name"
            return
        fi

        tmux_running=$(pgrep tmux)
        if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
            tmux new-session -s "$selected_name" -c "$selected"
        else
            if ! tmux has-session -t="$selected_name" 2> /dev/null; then
                tmux new-session -ds "$selected_name" -c "$selected"
            fi
            tmux switch-client -t "$selected_name"
        fi
    }

    # fuzzy match current directory contents
    ffuzz() {
        find . -wholename \*"$1"\* -not -path './.*/*' | fzf
    }

    #
    # Processes
    #

    # show process id - interactive grep
    fpid() {
        ps aux | fzf --header-lines=1 | awk '{print $2}'
    }

    # kill processes - list only the ones you can kill. Default signal is
    # SIGTERM (15); pass an explicit signal number for harsher signals,
    # e.g. `fpkill 9`.
    fpkill() {
        local pid
        if [ "$UID" != "0" ]; then
            pid=$(ps -f -u "$UID" | fzf -m --header-lines=1 | awk '{print $2}')
        else
            pid=$(ps -ef | fzf -m --header-lines=1 | awk '{print $2}')
        fi
        if [ -n "$pid" ]; then
            echo "$pid" | xargs kill -"${1:-15}"
        fi
    }

    #
    # System
    #
    # source "${HOME}/.config/shell/system/fzf-system"
    # fzf-sys() {
    #     ${HOME}/.config/shell/system/fzf-system"
    # }

    fsys() {
        [[ -f "$HOME"/.local/bin/+fzf-system ]] && "$HOME"/.local/bin/+fzf-system "$@"
    }

    #
    # Git
    #

    # fbr - checkout git branch (including remote branches)
    fbr() {
        local branches branch
        branches=$(git branch --all | grep -v HEAD) &&
            branch=$(echo "$branches" | fzf +m) &&
            git checkout "$(echo "$branch" | sed "s/.* //" | sed "s#remotes/[^/]*/##")"
    }

    # fco - checkout git branch/tag
    fco() {
        local tags branches target
        branches=$(
            git --no-pager branch --all \
                --format="%(if)%(HEAD)%(then)%(else)%(if:equals=HEAD)%(refname:strip=3)%(then)%(else)%1B[0;34;1mbranch%09%1B[m%(refname:short)%(end)%(end)" |
                sed '/^$/d'
        )         || return
        tags=$(git --no-pager tag | awk '{print "\x1b[35;1mtag\x1b[m\t" $1}') || return
        target=$(
            (
                echo "$branches"
                echo "$tags"
            ) |
                fzf --no-hscroll --no-multi -n 2 \
                    --ansi
        )       || return
        git checkout "$(awk '{print $2}' <<< "$target")"
    }

    # fcoc - checkout git commit
    fcoc() {
        local commits commit
        commits=$(git log --pretty=oneline --abbrev-commit) &&
            commit=$(echo "$commits" | fzf +s +m -e) &&
            git checkout "$(echo "$commit" | sed "s/ .*//")"
    }

    # fshow - git commit browser.
    # NOTE: do not reformat -- the `FZF-EOF` heredoc marker must remain at
    # column 1 (no indent) or the bind breaks. shfmt / shellharden will
    # destroy this block.
    fshow() {
        git log --graph --color=always \
            --format="%C(auto)%h%d %s %C(black)%C(bold)%cr" "$@" |
            fzf --ansi --no-sort --reverse --tiebreak=index --bind=ctrl-s:toggle-sort \
                --bind "ctrl-m:execute:
                (grep -o '[a-f0-9]\{7\}' | head -1 |
                xargs -I % sh -c 'git show --color=always % | less -R') << 'FZF-EOF'
                {}
FZF-EOF"
    }

    #
    # Pass
    #
    if type pass > /dev/null 2> /dev/null; then
        fpass() {
            local store="$HOME/.password-store/"
            local swapfile="/swap/swapfile" # Set path to any swapfile not listed in /etc/fstab
            local selection arg tmp

            # Open pass tomb, if any
            if [[ -e "$HOME/.password.tomb" ]]; then
                sudo swapoff -a && sudo swapoff "${swapfile}" 2> /dev/null
                pass open 2> /dev/null
            fi

            while :; do
                clear
                selection=$(fd .gpg ~/.password-store/ |
                                  fzf --query "${tmp}" \
                                      --with-nth 5.. \
                                      --delimiter "/" \
                                      --no-multi \
                                      --header='
Ret: copy, M-s: show, M-e: edit, M-r: rename, M-d: duplicate,
M-a: add, M-g: generate and copy new password, M-t: trash
M-p: git pull, M-P: git push, C-g/Esc: clear query or exit' \
                                      --bind="alt-s:execute(echo 'show' > /tmp/passfzfarg)+accept" \
                                      --bind="alt-e:execute(echo 'edit' > /tmp/passfzfarg)+accept" \
                                      --bind="alt-r:execute(echo 'mv' > /tmp/passfzfarg)+accept" \
                                      --bind="alt-d:execute(echo 'cp' > /tmp/passfzfarg)+accept" \
                                      --bind="alt-a:execute(echo 'add' > /tmp/passfzfarg)+print-query" \
                                      --bind="alt-g:execute(echo 'generate --clip' > /tmp/passfzfarg)+print-query" \
                                      --bind="alt-t:execute(echo 'rm' > /tmp/passfzfarg)+accept" \
                                      --bind="alt-p:abort+execute(echo 'git pull' > /tmp/passfzfarg)" \
                                      --bind="alt-P:abort+execute(echo 'git push -u --all' > /tmp/passfzfarg)" \
                                      --bind="ctrl-g:execute(echo 'quit' > /tmp/passfzfarg)+cancel" \
                                      --bind="esc:execute(echo 'quit' > /tmp/passfzfarg)+cancel")

                if [[ -f "/tmp/passfzfarg" ]]; then
                    arg=$(cat /tmp/passfzfarg)
                    rm /tmp/passfzfarg

                    # quit: can be clear or exit
                    if [[ "$arg" = "quit" ]]; then
                        # no selection means exit
                        [[ -z "$selection" ]] && break

                        # new selection means start over
                        [[ -n "$selection" ]] && arg="show --clip"
                    fi
                else
                    arg="show --clip"
                fi

                clear
                case "$arg" in
                    add)
                        printf '\033[0;32mNew password Directory/Name:\033[0m %s' "$selection"
                        if [[ -n "$selection" ]]; then
                            printf '\033[0;32m\nPress Return to confirm or type new Directory/Name:\033[0m '
                        fi
                        read -r
                        tmp="${REPLY:=$selection}"
                        pass ${arg} "${tmp}"
                        tmp="${selection:=$tmp}"
                        continue
                        ;;
                    mv | cp)
                        tmp=${selection::-4} && tmp=${tmp#"$store"}
                        printf "\033[0;32m\nNew Directory/Name to %s '%s' to:\033[0m " "$arg" "$tmp"
                        read -r
                        if [[ -n "$REPLY" ]]; then
                            pass ${arg} "${tmp}" "${REPLY}"
                        fi
                        tmp="${REPLY:=$tmp}"
                        continue
                        ;;
                    "generate --clip")
                        printf '\033[0;32mNew password Directory/Name:\033[0m %s' "$selection"
                        if [[ -n "$selection" ]]; then
                            printf '\033[0;32m\nPress Return to confirm or type new Directory/Name:\033[0m '
                        fi
                        read -r
                        tmp="${REPLY:=$selection}"
                        printf '\033[0;32mNumber of characters:\033[0m '
                        read -r
                        pass ${arg} --in-place "${tmp}" "${REPLY}" \
                            2> /dev/null  || pass ${arg} "${tmp}" "${REPLY}"
                        tmp="${selection:=$tmp}"
                        printf '\nPress any key to continue. '
                        read -rsn1
                        continue
                        ;;
                    quit)
                        if [[ -z "$selection" ]]; then
                            pkill -P $$
                            break
                        fi
                        continue
                        ;;
                    *)
                        if [[ -n "$selection" ]]; then
                            tmp=${selection::-4} && tmp=${tmp#"$store"}
                            pass ${arg} "${tmp}"
                        else
                            pass ${arg}
                        fi
                        printf '\nPress any key to continue. '
                        read -rsn1
                        continue
                        ;;
                esac
            done

            # Close pass tomb, if any
            if [[ -e "$HOME/.password.tomb" ]]; then
                printf "\n"
                pass close
                sudo swapon -a && sudo swapon "${swapfile}" 2> /dev/null
            fi
        }
    fi
fi
